import { service } from "@/services/axios";

// ${subTable.functionName}分页列表
export const listPage${subClassName} = (params?: Record<string, any>) => {
  return service({
    method: "get",
    url: "/${moduleName}/${businessName}/sub/list/page",
    params: params || {}, // 无参数时传空对象
  }).then((response) => response.data);
};

// ${subTable.functionName}详情
export const get${subClassName}Detail = (${subTablePkColumn.javaField}: number) => {
  return service({
    method: 'get',
    url: "/${moduleName}/${businessName}/sub/detail",
    params: {"${subTablePkColumn.javaField}":${subTablePkColumn.javaField}},
  })
}

//添加${subTable.functionName}
export const add${subClassName} = (params?: Record<string, any>) => {
  return service({
    method: "post",
    url: "/${moduleName}/${businessName}/sub/add",
    data: params || {}, // 无参数时传空对象
  }).then((response) => response.data);
};

// 编辑${subTable.functionName}
export const modify${subClassName} = (params?: Record<string, any>) => {
  return service({
    method: 'post',
    url: "/${moduleName}/${businessName}/sub/modify",
    data: params || {}, // 无参数时传空对象
  }).then((response) => response.data);
}

//删除${subTable.functionName}
export const delete${subClassName} = (${subTablePkColumn.javaField}s: any) => {
  return service({
    method: "delete",
    url: "/${moduleName}/${businessName}/sub/delete",
    params: ${subTablePkColumn.javaField}s, // 通过 URL 参数传递（如 /generator/delete?tableId=1）
  }).then((response) => response.data);
};