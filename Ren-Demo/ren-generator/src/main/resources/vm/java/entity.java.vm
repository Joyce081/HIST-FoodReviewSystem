package ${packageName}.core.domain.entity;

#if(${table.tree})
import java.util.ArrayList;
import java.util.List;
#end

import com.baomidou.mybatisplus.annotation.IdType;
import com.baomidou.mybatisplus.annotation.TableField;
import com.baomidou.mybatisplus.annotation.TableId;
import com.baomidou.mybatisplus.annotation.TableName;

import com.ren.common.core.domain.entity.BaseEntity;

import io.swagger.v3.oas.annotations.media.Schema;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

#foreach ($import in $importList)
import ${import};
#end

/**
 * ${functionName}对象 ${tableName}
 *
 * @author ${author}
 * @date ${datetime}
 */
@Data
@AllArgsConstructor
@NoArgsConstructor
@TableName("${tableName}")
public class ${ClassName} extends BaseEntity {
	private static final long serialVersionUID = 1L;

    #foreach($column in $columns)
    #if($column.isPk())
	/** $column.columnComment */
	@TableId(value = "$column.columnName", type = IdType.AUTO)
	@Schema(description = "${column.columnComment}(添加时为空)")
	private $column.javaType $column.javaField;
	#elseif(($column.usableColumn) || (!$column.superColumn))
	/** $column.columnComment */
	@TableField(value = "$column.columnName")
	@Schema(description = "${column.columnComment}")
	private $column.javaType $column.javaField;
    #end
    #end

	#if($table.sub || $table.tree)
	/*==================================================以下为冗余字段===================================================*/
	#end

	#if($table.sub)
	/** ${subTable.functionName}信息 */
	@TableField(exist = false)
	@Schema(hidden = true)
	private List<${subClassName}> ${subclassName}List;
	#end

	#if($table.tree)
	/** 树子节点列表信息 */
	@TableField(exist = false)
	@Schema(hidden = true)
	private List<${ClassName}> children = new ArrayList<>();
	#end

}